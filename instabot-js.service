[Unit]
Description=InstaBot JS Webhook
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/instabot-js
EnvironmentFile=/opt/instabot-js/.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5
User=root
Group=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
